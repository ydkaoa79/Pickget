                              width: currentWidthA, 
                              child: ClipRect(
                                child: UnconstrainedBox(
                                  clipBehavior: Clip.hardEdge,
                                  alignment: Alignment.topCenter,
                                  child: SizedBox(
                                    width: sw * 0.8,
