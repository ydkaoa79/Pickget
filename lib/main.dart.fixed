                      // VS Badge
                      AnimatedPositioned(
                        duration: _isDragging ? Duration.zero : const Duration(milliseconds: 400), 
                        curve: Curves.easeOutCubic, 
                        left: (currentWidthA - 24).clamp(-24.0, sw - 24.0), 
                        child: IgnorePointer(
