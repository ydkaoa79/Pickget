                                      ? Image.network(widget.post.imageA, fit: BoxFit.fitWidth, alignment: Alignment.topCenter)
                                      : Image.asset(widget.post.imageA, fit: BoxFit.fitWidth, alignment: Alignment.topCenter),
                                  ),
