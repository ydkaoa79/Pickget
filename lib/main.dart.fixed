                                      ? Image.network(widget.post.imageB, fit: BoxFit.fitWidth, alignment: Alignment.topCenter)
                                      : Image.asset(widget.post.imageB, fit: BoxFit.fitWidth, alignment: Alignment.topCenter),
                                  ),
